## 📏 Step 6: Model Evaluation
Comparing models using MAE, RMSE, and MAPE metrics.


======================================== CELL 17 (code) ========================================
def evaluate(name, actual, predicted):
    mae  = mean_absolute_error(actual, predicted)
    rmse = np.sqrt(mean_squared_error(actual, predicted))
    mape = np.mean(np.abs((actual - predicted) / actual)) * 100
    return {'Model': name, 'MAE (₹ Cr)': round(mae, 2),
            'RMSE (₹ Cr)': round(rmse, 2), 'MAPE (%)': round(mape, 2)}

results = [
    evaluate('Linear Regression', y_test.values, lr_pred),
    evaluate('Random Forest',     y_test.values, rf_pred),
    evaluate('XGBoost',           y_test.values, xgb_pred),
    evaluate('Prophet',           y_test.values, prophet_test_pred),
]

df_results = pd.DataFrame(results).sort_values('RMSE (₹ Cr)')
print("=" * 60)
print("📊 MODEL EVALUATION RESULTS")
print("=" * 60)
print(df_results.to_string(index=False))
print("\n🏆 Best Model:", df_results.iloc[0]['Model'])


