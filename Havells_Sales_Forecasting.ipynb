    "# ── Evaluation Chart ──────────────────────────────────────────────────────────\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.suptitle('Model Evaluation Comparison', fontsize=14, fontweight='bold')\n",
    "\n",
    "# RMSE comparison\n",
    "ax = axes[0]\n",
    "colors_eval = ['#4361ee','#06d6a0','#f77f00','#ef233c']\n",
    "bars = ax.bar(df_results['Model'], df_results['RMSE (₹ Cr)'], color=colors_eval, alpha=0.85)\n",
    "for bar, val in zip(bars, df_results['RMSE (₹ Cr)']):\n",
    "    ax.text(bar.get_x()+bar.get_width()/2, bar.get_height()+50,\n",
    "            f'₹{val:,.0f}', ha='center', fontsize=9, fontweight='bold')\n",
    "ax.set_title('RMSE Comparison (lower = better)')\n",
    "ax.set_ylabel('RMSE (₹ Crores)')\n",
    "ax.set_facecolor('#f0f4ff')\n",
    "ax.tick_params(axis='x', rotation=15)\n",
    "\n",
    "# MAPE comparison\n",
    "ax = axes[1]\n",
    "bars = ax.bar(df_results['Model'], df_results['MAPE (%)'], color=colors_eval, alpha=0.85)\n",
