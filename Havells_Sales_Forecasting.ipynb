# ── Model 4: Facebook Prophet ─────────────────────────────────────────────────
df_prophet = df_annual[['Date', 'Sales_Cr']].rename(columns={'Date':'ds','Sales_Cr':'y'})
df_prophet_train = df_prophet.iloc[:-2]

prophet_model = Prophet(
    yearly_seasonality=True,
    interval_width=0.80,
    changepoint_prior_scale=0.05
)
prophet_model.fit(df_prophet_train)

# Predict for test period
future_test = prophet_model.make_future_dataframe(periods=2, freq='YE')
prophet_forecast = prophet_model.predict(future_test)
prophet_test_pred = prophet_forecast['yhat'].tail(2).values

print("✅ Facebook Prophet trained!")
print(f"\nProphet test predictions: {[f'₹{v:,.0f}' for v in prophet_test_pred]}")
print(f"Actual values:           {[f'₹{v:,.0f}' for v in y_test.values]}")


