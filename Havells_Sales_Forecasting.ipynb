   "source": [
    "## ⚙️ Step 4: Feature Engineering\n",
    "Creating time-based features to help ML models understand temporal patterns.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "15486382",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Features created:\n",
      "  FY  Sales_Cr  Year_Num  Sales_Lag1  Sales_Lag2  Rolling_Mean\n",
      "2019  10073.43         2     8116.21     6130.16   8106.600000\n",
      "2020   9440.26         3    10073.43     8116.21   9209.966667\n",
      "2021  10457.30         4     9440.26    10073.43   9990.330000\n",
      "2022  13938.48         5    10457.30     9440.26  11278.680000\n",
      "2023  16910.73         6    13938.48    10457.30  13768.836667\n",
      "2024  18590.01         7    16910.73    13938.48  16479.740000\n",
      "2025  21778.06         8    18590.01    16910.73  19092.933333\n",
      "2026  22527.77         9    21778.06    18590.01  20965.280000\n"
     ]
    }
   ],
   "source": [
    "# Create feature-rich dataframe for ML models\n",
    "df_ml = df_annual.copy()\n",
    "df_ml['Year_Num']     = np.arange(len(df_ml))          # 0, 1, 2, ...\n",
    "df_ml['Sales_Lag1']   = df_ml['Sales_Cr'].shift(1)     # Previous year sales\n",
    "df_ml['Sales_Lag2']   = df_ml['Sales_Cr'].shift(2)     # 2 years ago\n",
    "df_ml['Rolling_Mean'] = df_ml['Sales_Cr'].rolling(3).mean()  # 3-year avg\n",
    "df_ml = df_ml.dropna().reset_index(drop=True)\n",
    "\n",
    "print(\"✅ Features created:\")\n",
    "print(df_ml[['FY','Sales_Cr','Year_Num','Sales_Lag1','Sales_Lag2','Rolling_Mean']].to_string(index=False))\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "04730cac",
   "metadata": {},
   "source": [
    "## 🤖 Step 5: Model Building & Training\n",
    "We train 4 models and compare their performance.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3e24ed0c",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Training samples: 6 | Test samples: 2\n"
     ]
    }
   ],
   "source": [
    "# ── Train/Test Split ──────────────────────────────────────────────────────────\n",
    "features = ['Year_Num', 'Sales_Lag1', 'Sales_Lag2', 'Rolling_Mean']\n",
    "X = df_ml[features]\n",
    "y = df_ml['Sales_Cr']\n",
    "\n",
    "# Use last 2 years as test\n",
    "X_train, X_test = X.iloc[:-2], X.iloc[-2:]\n",
    "y_train, y_test = y.iloc[:-2], y.iloc[-2:]\n",
    "\n",
    "print(f\"Training samples: {len(X_train)} | Test samples: {len(X_test)}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f2d4c1bd",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Linear Regression trained!\n",
      "✅ Random Forest trained!\n",
      "✅ XGBoost trained!\n"
     ]
    }
   ],
   "source": [
    "# ── Model 1: Linear Regression ───────────────────────────────────────────────\n",
    "lr = LinearRegression()\n",
    "lr.fit(X_train, y_train)\n",
    "lr_pred = lr.predict(X_test)\n",
    "print(\"✅ Linear Regression trained!\")\n",
    "\n",
    "# ── Model 2: Random Forest ────────────────────────────────────────────────────\n",
    "rf = RandomForestRegressor(n_estimators=100, random_state=42)\n",
    "rf.fit(X_train, y_train)\n",
    "rf_pred = rf.predict(X_test)\n",
    "print(\"✅ Random Forest trained!\")\n",
    "\n",
    "# ── Model 3: XGBoost ──────────────────────────────────────────────────────────\n",
    "xgb = XGBRegressor(n_estimators=100, learning_rate=0.1, random_state=42, verbosity=0)\n",
    "xgb.fit(X_train, y_train)\n",
    "xgb_pred = xgb.predict(X_test)\n",
    "print(\"✅ XGBoost trained!\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "509fa57c",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "INFO:prophet:Disabling weekly seasonality. Run prophet with weekly_seasonality=True to override this.\n",
      "INFO:prophet:Disabling daily seasonality. Run prophet with daily_seasonality=True to override this.\n",
      "INFO:prophet:n_changepoints greater than number of observations. Using 5.\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ Facebook Prophet trained!\n",
      "\n",
      "Prophet test predictions: ['₹31,574', '₹34,443']\n",
      "Actual values:           ['₹21,778', '₹22,528']\n"
     ]
    }
   ],
   "source": [
    "# ── Model 4: Facebook Prophet ─────────────────────────────────────────────────\n",
    "df_prophet = df_annual[['Date', 'Sales_Cr']].rename(columns={'Date':'ds','Sales_Cr':'y'})\n",
    "df_prophet_train = df_prophet.iloc[:-2]\n",
    "\n",
    "prophet_model = Prophet(\n",
    "    yearly_seasonality=True,\n",
    "    interval_width=0.80,\n",
    "    changepoint_prior_scale=0.05\n",
    ")\n",
    "prophet_model.fit(df_prophet_train)\n",
    "\n",
    "# Predict for test period\n",
    "future_test = prophet_model.make_future_dataframe(periods=2, freq='YE')\n",
    "prophet_forecast = prophet_model.predict(future_test)\n",
    "prophet_test_pred = prophet_forecast['yhat'].tail(2).values\n",
    "\n",
    "print(\"✅ Facebook Prophet trained!\")\n",
    "print(f\"\\nProphet test predictions: {[f'₹{v:,.0f}' for v in prophet_test_pred]}\")\n",
    "print(f\"Actual values:           {[f'₹{v:,.0f}' for v in y_test.values]}\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "692e0fea",
   "metadata": {},
   "source": [
    "## 📏 Step 6: Model Evaluation\n",
    "Comparing models using MAE, RMSE, and MAPE metrics.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cae80dcc",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "============================================================\n",
      "📊 MODEL EVALUATION RESULTS\n",
      "============================================================\n",
      "            Model  MAE (₹ Cr)  RMSE (₹ Cr)  MAPE (%)\n",
      "Linear Regression        0.00         0.00      0.00\n",
      "          XGBoost     3594.58      3614.07     16.20\n",
      "    Random Forest     4375.20      4391.23     19.73\n",
      "          Prophet    10855.76     10907.38     48.94\n",
      "\n",
      "🏆 Best Model: Linear Regression\n"
     ]
    }
   ],
   "source": [
    "def evaluate(name, actual, predicted):\n",
    "    mae  = mean_absolute_error(actual, predicted)\n",
    "    rmse = np.sqrt(mean_squared_error(actual, predicted))\n",
    "    mape = np.mean(np.abs((actual - predicted) / actual)) * 100\n",
    "    return {'Model': name, 'MAE (₹ Cr)': round(mae, 2),\n",
    "            'RMSE (₹ Cr)': round(rmse, 2), 'MAPE (%)': round(mape, 2)}\n",
    "\n",
    "results = [\n",
    "    evaluate('Linear Regression', y_test.values, lr_pred),\n",
    "    evaluate('Random Forest',     y_test.values, rf_pred),\n",
    "    evaluate('XGBoost',           y_test.values, xgb_pred),\n",
    "    evaluate('Prophet',           y_test.values, prophet_test_pred),\n",
    "]\n",
    "\n",
    "df_results = pd.DataFrame(results).sort_values('RMSE (₹ Cr)')\n",
    "print(\"=\" * 60)\n",
    "print(\"📊 MODEL EVALUATION RESULTS\")\n",
    "print(\"=\" * 60)\n",
    "print(df_results.to_string(index=False))\n",
    "print(\"\\n🏆 Best Model:\", df_results.iloc[0]['Model'])\n"
   ]
  },
